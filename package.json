{
  "name": "k-design-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build:packages": "pnpm --filter @kdesign/editor-core build && pnpm --filter @kdesign/preview-runtime build && pnpm --filter @kdesign/export-worker build",
    "dev": "pnpm --filter @kdesign/web dev",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false --force",
    "test": "pnpm build:packages && vitest run",
    "test:watch": "vitest",
    "e2e": "pnpm build:packages && playwright test"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "@types/node": "25.6.0",
    "eslint": "10.2.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
